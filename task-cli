#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
JAR="$SCRIPT_DIR/target/task-cli.jar"

if [[ ! -f "$JAR" ]]; then
  echo "Building task-cli..."
  mvn -q package -f "$SCRIPT_DIR/pom.xml"
fi

exec java -Dfile.encoding=UTF-8 -Dstdout.encoding=UTF-8 -jar "$JAR" "$@"